{
  "name": "dygita-theme",
  "version": "1.0.0",
  "description": "Dygita Typecho Theme Build Tools",
  "main": "tools/build-css.js",
  "scripts": {
    "build-css": "node tools/build-css.js",
    "build-css:prod": "node tools/build-css.js --production",
    "build-js": "node tools/build-js.js",
    "build-js:prod": "node tools/build-js.js --production",
    "lint:js": "eslint \"js/**/*.js\" --ignore-pattern \"js/vendor/**\" --ignore-pattern \"js/dist/**\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "build": "npm run lint && npm run build-css:prod && npm run build-js:prod"
  },
  "devDependencies": {
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.1",
    "eslint": "^8.54.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "terser": "^5.24.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ]
}
